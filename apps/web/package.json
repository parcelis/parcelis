{
  "name": "@parcelis/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/run-with-open-port.mjs PORT 3000 next dev --turbo --hostname 0.0.0.0 --port {PORT}",
    "dev:fixed": "next dev --turbo --hostname 0.0.0.0 --port ${PORT:-3000}",
    "build": "next build",
    "start": "node ../../scripts/run-with-open-port.mjs PORT 3000 next start --port {PORT}",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@parcelis/api": "workspace:*",
    "@parcelis/schemas": "workspace:*",
    "@parcelis/ui": "workspace:*",
    "@tanstack/react-query": "^5.59.16",
    "@trpc/client": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@parcelis/config": "workspace:*",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  }
}
