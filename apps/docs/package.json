{
  "name": "@parcelis/docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ../../scripts/run-with-open-port.mjs PORT 3001 docusaurus start --host 0.0.0.0 --port {PORT}",
    "dev:fixed": "docusaurus start --host 0.0.0.0 --port ${PORT:-3001}",
    "build": "docusaurus build",
    "start": "node ../../scripts/run-with-open-port.mjs PORT 3001 docusaurus serve --host 0.0.0.0 --port {PORT}",
    "serve": "docusaurus serve --host 0.0.0.0 --port ${PORT:-3001}",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.2",
    "@docusaurus/preset-classic": "3.10.2",
    "@mdx-js/react": "^3.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@docusaurus/plugin-content-docs": "3.10.2",
    "@docusaurus/tsconfig": "3.10.2",
    "@docusaurus/types": "3.10.2",
    "@types/node": "^22.7.4",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "typescript": "^5.6.2"
  }
}
