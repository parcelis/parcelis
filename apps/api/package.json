{
  "name": "@parcelis/api",
  "version": "0.1.0",
  "private": true,
  "exports": {
    "./router": {
      "types": "./src/router/app.router.ts",
      "default": "./src/router/app.router.ts"
    }
  },
  "scripts": {
    "dev": "node ../../scripts/run-with-open-port.mjs API_PORT 4000 nest start --watch",
    "dev:fixed": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@parcelis/db": "workspace:*",
    "@parcelis/schemas": "workspace:*",
    "@trpc/server": "^10.45.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@parcelis/config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2"
  }
}
