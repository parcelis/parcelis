{
  "name": "parcelis",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source property management platform for boutique operators.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "turbo build",
    "dev": "node scripts/dev-local.mjs",
    "dev:turbo": "turbo dev --parallel",
    "postinstall": "pnpm db:generate",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @parcelis/db db:generate",
    "db:migrate": "pnpm --filter @parcelis/db db:migrate",
    "db:seed": "pnpm --filter @parcelis/db db:seed"
  },
  "devDependencies": {
    "@parcelis/config": "workspace:*",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
