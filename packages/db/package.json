{
  "name": "@parcelis/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "node ../../scripts/prisma-with-env.mjs generate",
    "db:migrate": "node ../../scripts/prisma-with-env.mjs migrate dev",
    "db:seed": "node ../../scripts/prisma-with-env.mjs db seed",
    "db:studio": "node ../../scripts/prisma-with-env.mjs studio",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0"
  },
  "devDependencies": {
    "@parcelis/config": "workspace:*",
    "prisma": "^5.20.0",
    "typescript": "^5.6.2"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
